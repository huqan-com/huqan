{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SimulationResult",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "mode",
    "input",
    "affectedNodes",
    "causalChains",
    "risks",
    "confidence",
    "recommendation",
    "evidence",
    "unknowns"
  ],
  "properties": {
    "mode": { "type": "string" },
    "input": { "type": ["object", "string", "null"] },
    "affectedNodes": { "type": "array" },
    "causalChains": { "type": "array" },
    "risks": { "type": "array" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "recommendation": { "type": "string" },
    "evidence": { "type": "array" },
    "unknowns": { "type": "array" }
  },
  "description": "Simulation results are explainable forecasts, not absolute predictions."
}
